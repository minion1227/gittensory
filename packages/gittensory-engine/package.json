{
  "name": "@jsonbored/gittensory-engine",
  "version": "0.2.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "Shared deterministic engine logic for the Gittensory review stack and gittensory-miner.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JSONbored/gittensory.git",
    "directory": "packages/gittensory-engine"
  },
  "homepage": "https://github.com/JSONbored/gittensory#readme",
  "bugs": {
    "url": "https://github.com/JSONbored/gittensory/issues"
  },
  "keywords": [
    "gittensor",
    "gittensory",
    "engine",
    "deterministic",
    "scoring",
    "signals"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./scoring/model": {
      "types": "./dist/scoring/model.d.ts",
      "default": "./dist/scoring/model.js"
    },
    "./scoring/preview": {
      "types": "./dist/scoring/preview.d.ts",
      "default": "./dist/scoring/preview.js"
    },
    "./scoring/pending-pr-scenarios": {
      "types": "./dist/scoring/pending-pr-scenarios.d.ts",
      "default": "./dist/scoring/pending-pr-scenarios.js"
    },
    "./signals/test-evidence": {
      "types": "./dist/signals/test-evidence.d.ts",
      "default": "./dist/signals/test-evidence.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test \"dist-test/**/*.test.js\""
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
